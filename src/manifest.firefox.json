{
  "manifest_version": 2,
  "name": "Autodarts Training Plans",
  "description": "Adds a training plans overlay to play.autodarts.io so you can play back-to-back game sessions hands-free.",
  "version": "1.0.0",
  "permissions": [
    "https://api.autodarts.io/*"
  ],
  "web_accessible_resources": [
    "injected.js"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://play.autodarts.io/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "autodarts-training@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}