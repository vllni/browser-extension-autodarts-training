{
  "manifest_version": 3,
  "name": "Autodarts Training Plans",
  "description": "Adds a training plans overlay to play.autodarts.io so you can play back-to-back game sessions hands-free.",
  "version": "1.0.4",
  "content_scripts": [
    {
      "matches": [
        "https://play.autodarts.io/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}